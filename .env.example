# Backend Configuration
DEVICE=cpu                          # cpu or cuda
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Model Configuration
MODEL_PATH=models/aotgan_best.pth
IMAGE_SIZE=512
BATCH_SIZE=1

# FastAPI
RELOAD=true                         # auto-reload on changes (development only)
WORKERS=1

# Frontend Configuration (if not using SSR)
FRONTEND_PORT=4200
ANGULAR_ENV=development

# Database (optional - for chain of custody logs)
DATABASE_URL=sqlite:///./forensic.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here-change-in-production

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
